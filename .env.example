# Provide ONE of these. If both are set, ANTHROPIC takes precedence
# (override with PROVIDER=openai).
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# Optional overrides
# PROVIDER=anthropic            # "anthropic" or "openai" — auto-detected if unset
# MODEL=claude-opus-4-7         # default per provider

# Supabase PostgreSQL connection string
# Get this from: Supabase dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
